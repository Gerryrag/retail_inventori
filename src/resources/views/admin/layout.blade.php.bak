<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@yield('title', 'Admin') - Official Merchandise</title>
    <!-- Import Google Font Inter for premium typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        :root {
            /* Colors from DESIGN.md (Minimalist Merch Admin Dashboard) */
            --bg: #fbf8fa;
            --surface: #ffffff;
            --surface-soft: #f5f3f4;
            --surface-container: #f0edef;
            --surface-container-high: #eae7e9;
            --surface-container-highest: #e4e2e3;
            --on-surface: #1b1b1d;
            --on-surface-variant: #45474c;
            --inverse-surface: #303032;
            --inverse-on-surface: #f3f0f2;
            
            --line: #c5c6cd; /* outline-variant */
            --line-light: #e4e2e3; /* surface-container-highest / faint border */
            --line-strong: #75777d; /* outline */
            
            --text: #1b1b1d; /* on-surface */
            --muted: #505f76; /* secondary */
            --muted-strong: #1b1b1d; /* on-surface */
            --charcoal: #091426; /* primary */
            --slate: #505f76; /* secondary */
            
            /* Accents */
            --emerald: #1b8a5a;
            --emerald-soft: rgba(27, 138, 90, 0.1);
            --amber: #d97706;
            --amber-soft: rgba(217, 119, 6, 0.1);
            --rose: #ba1a1a; /* error */
            --rose-soft: #ffdad6; /* error-container */
            
            /* Border Radius from DESIGN.md */
            --radius-sm: 0.125rem; /* 2px */
            --radius: 0.25rem; /* 4px */
            --radius-lg: 0.5rem; /* 8px */
            
            /* Spacing from DESIGN.md */
            --spacing-unit: 4px;
            --spacing-sm: 8px;
            --spacing-md: 16px;
            --spacing-lg: 24px;
            --spacing-xl: 32px;
            
            /* Shadow - Low contrast & diffused */
            --shadow-soft: 0 4px 12px rgba(0, 0, 0, 0.03);
            --shadow-hover: 0 8px 24px rgba(0, 0, 0, 0.05);
            
            --sidebar: 280px;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }
        
        html {
            background: var(--bg);
            scroll-behavior: smooth;
        }
        
        body {
            color: var(--text);
            background: var(--bg);
            font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        a {
            color: inherit;
            text-decoration: none;
            transition: all 0.2s ease;
        }
        
        button, input, select, textarea {
            font: inherit;
            color: inherit;
        }
        
        button {
            cursor: pointer;
            border: none;
            background: none;
        }
        
        form { margin: 0; }

        .layout {
            min-height: 100vh;
            padding-left: var(--sidebar);
            background: var(--bg);
        }

        aside {
            position: fixed;
            inset: 0 auto 0 0;
            z-index: 20;
            width: var(--sidebar);
            border-right: 1px solid var(--line-light);
            background: var(--surface); /* Sidebar on primary white plane */
            padding: 32px 20px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 0 8px 32px;
            color: var(--charcoal);
            font-weight: 700;
        }

        .brand-mark {
            display: grid;
            width: 36px;
            height: 36px;
            place-items: center;
            border-radius: var(--radius);
            background: var(--charcoal);
            color: white;
            font-size: 13px;
            font-weight: 700;
            letter-spacing: .05em;
        }

        .brand span {
            font-size: 15px;
            font-weight: 700;
            line-height: 1.2;
        }

        .brand small {
            display: block;
            margin-top: 2px;
            color: var(--muted);
            font-size: 11px;
            font-weight: 400;
        }

        .menu {
            display: grid;
            gap: 6px;
            align-content: start;
            flex-grow: 1;
        }

        .menu a {
            display: flex;
            min-height: 40px;
            align-items: center;
            gap: 12px;
            border-radius: var(--radius);
            padding: 0 12px;
            color: var(--muted);
            font-size: 13px;
            font-weight: 500;
            transition: all 0.2s ease;
        }

        .menu-icon {
            display: grid;
            width: 28px;
            height: 28px;
            place-items: center;
            border-radius: var(--radius);
            background: var(--surface-soft);
            color: var(--muted);
            transition: all 0.2s ease;
        }

        .menu-icon svg {
            width: 14px;
            height: 14px;
            stroke-width: 2px;
            transition: all 0.2s ease;
        }

        .menu a:hover {
            background: var(--surface-soft);
            color: var(--charcoal);
        }

        .menu a.active {
            background: var(--surface-soft);
            color: var(--charcoal);
            font-weight: 600;
        }

        .menu a.active .menu-icon {
            background: var(--charcoal);
            color: white;
        }

        .menu a.active .menu-icon svg {
            stroke: white;
        }

        .sidebar-foot {
            border-top: 1px solid var(--line-light);
            padding-top: 16px;
            color: var(--muted);
            font-size: 11px;
            line-height: 1.6;
        }

        main {
            min-width: 0;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .topbar {
            position: sticky;
            top: 0;
            z-index: 10;
            display: flex;
            min-height: 72px;
            align-items: center;
            justify-content: space-between;
            gap: 24px;
            border-bottom: 1px solid var(--line-light);
            background: var(--surface); /* Header on primary white plane */
            padding: 12px 32px;
        }

        .page-title h1 {
            color: var(--charcoal);
            font-size: 20px;
            font-weight: 600;
            letter-spacing: -0.01em;
            line-height: 1.2;
        }

        .page-title p {
            margin-top: 4px;
            color: var(--muted);
            font-size: 12px;
        }

        .top-tools {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .global-search {
            position: relative;
            width: 280px;
        }

        .global-search input {
            width: 100%;
            min-height: 38px;
            border: 1px solid var(--line-light);
            border-radius: var(--radius);
            padding: 0 12px 0 34px;
            background: var(--surface);
            color: var(--text);
            font-size: 13px;
            transition: all 0.2s ease;
        }

        .global-search input:focus {
            border-color: var(--slate);
        }

        .global-search svg {
            position: absolute;
            top: 50%;
            left: 12px;
            transform: translateY(-50%);
            color: var(--muted);
        }

        .icon-button {
            position: relative;
            display: inline-grid;
            width: 38px;
            height: 38px;
            place-items: center;
            border: 1px solid var(--line-light);
            border-radius: var(--radius);
            background: var(--surface);
            color: var(--charcoal);
            font-size: 14px;
            transition: all 0.2s ease;
        }

        .icon-button:hover {
            border-color: var(--line);
            background: var(--surface-soft);
        }

        .icon-button .count {
            position: absolute;
            top: -4px;
            right: -4px;
            display: grid;
            min-width: 16px;
            height: 16px;
            place-items: center;
            border-radius: 999px;
            background: var(--rose);
            color: white;
            font-size: 9px;
            font-weight: 700;
            padding: 0 4px;
        }
        /* Notification Dropdown */
        .notif-wrapper {
            position: relative;
        }
        .notif-dropdown {
            display: none;
            position: absolute;
            top: calc(100% + 8px);
            right: 0;
            width: 340px;
            background: var(--surface);
            border: 1px solid var(--line-light);
            border-radius: var(--radius-lg);
            box-shadow: 0 8px 24px rgba(0,0,0,0.08), 0 2px 8px rgba(0,0,0,0.04);
            z-index: 999;
            overflow: hidden;
            animation: slideDown 0.18s cubic-bezier(0.16,1,0.3,1);
        }
        .notif-dropdown.open { display: block; }
        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-6px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .notif-dropdown-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 16px 10px;
            border-bottom: 1px solid var(--line-light);
        }
        .notif-dropdown-head strong {
            font-size: 13px;
            font-weight: 600;
            color: var(--charcoal);
        }
        .notif-dropdown-head a {
            font-size: 11px;
            color: var(--muted);
            text-decoration: none;
            transition: color 0.15s;
        }
        .notif-dropdown-head a:hover { color: var(--charcoal); }
        .notif-list {
            max-height: 360px;
            overflow-y: auto;
        }
        .notif-row {
            display: grid;
            grid-template-columns: auto 1fr;
            gap: 10px;
            align-items: flex-start;
            padding: 12px 16px;
            border-bottom: 1px solid var(--line-light);
            text-decoration: none;
            transition: background 0.15s;
            cursor: pointer;
        }
        .notif-row:last-child { border-bottom: none; }
        .notif-row:hover { background: var(--surface-soft); }
        .notif-dot {
            width: 8px;
            height: 8px;
            border-radius: 999px;
            margin-top: 4px;
            flex-shrink: 0;
        }
        .notif-dot.danger { background: var(--rose); }
        .notif-dot.warning { background: var(--amber); }
        .notif-dot.info { background: var(--charcoal); }
        .notif-dot.order { background: var(--emerald); }
        .notif-row-title {
            font-size: 12px;
            font-weight: 600;
            color: var(--charcoal);
            line-height: 1.4;
        }
        .notif-row-msg {
            font-size: 11px;
            color: var(--muted);
            margin-top: 2px;
            line-height: 1.4;
        }
        .notif-empty {
            padding: 24px 16px;
            text-align: center;
            font-size: 12px;
            color: var(--muted);
        }
        .notif-footer {
            padding: 10px 16px;
            border-top: 1px solid var(--line-light);
            text-align: center;
        }
        .notif-footer a {
            font-size: 12px;
            color: var(--muted);
            text-decoration: none;
            transition: color 0.15s;
        }
        .notif-footer a:hover { color: var(--charcoal); }


        .avatar {
            display: flex;
            align-items: center;
            gap: 8px;
            border: 1px solid var(--line-light);
            border-radius: var(--radius);
            padding: 4px 10px 4px 4px;
            background: var(--surface);
        }

        .avatar img,
        .avatar-initial {
            display: grid;
            width: 28px;
            height: 28px;
            place-items: center;
            border-radius: var(--radius-sm);
            background: var(--charcoal);
            color: white;
            font-size: 11px;
            font-weight: 600;
            object-fit: cover;
        }

        .avatar strong {
            max-width: 100px;
            overflow: hidden;
            color: var(--charcoal);
            font-size: 12px;
            font-weight: 500;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .content {
            display: grid;
            gap: var(--spacing-lg);
            padding: var(--spacing-lg) var(--spacing-xl) var(--spacing-xl);
            background: var(--bg);
            flex-grow: 1;
        }

        .button,
        .secondary-button,
        .danger-button,
        .ghost-button {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 36px;
            border-radius: var(--radius);
            padding: 0 16px;
            font-size: 13px;
            font-weight: 500;
            transition: all 0.2s ease;
        }

        .button {
            background: var(--charcoal);
            color: white;
        }
        
        .button:hover {
            opacity: 0.9;
        }

        .secondary-button {
            border: 1px solid var(--line-strong);
            background: transparent;
            color: var(--muted);
        }

        .secondary-button:hover {
            background: var(--surface-soft);
            color: var(--charcoal);
        }

        .ghost-button {
            background: transparent;
            color: var(--muted);
        }

        .ghost-button:hover {
            background: var(--surface-soft);
            color: var(--charcoal);
        }

        .danger-button {
            background: var(--rose);
            color: white;
        }

        .danger-button:hover {
            opacity: 0.9;
        }

        .status,
        .errors {
            border: 1px solid var(--emerald);
            border-radius: var(--radius);
            padding: 12px 16px;
            background: var(--emerald-soft);
            color: var(--emerald);
            font-size: 13px;
            font-weight: 500;
        }

        .errors {
            border-color: var(--rose);
            background: var(--rose-soft);
            color: var(--rose);
        }

        /* Stats Cards in Grid */
        .stats {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: var(--spacing-md);
        }

        .stat,
        .panel {
            border: 1px solid var(--line-light);
            border-radius: var(--radius-lg);
            background: var(--surface);
            transition: all 0.2s ease;
        }

        .stat {
            padding: 20px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            min-height: 110px;
        }

        .stat:hover {
            box-shadow: var(--shadow-soft);
            border-color: var(--line);
        }

        .stat-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            width: 100%;
        }

        .stat-header span {
            color: var(--muted);
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .stat-header svg {
            color: var(--muted);
            opacity: 0.7;
        }

        .stat strong {
            display: block;
            margin-top: 8px;
            color: var(--charcoal);
            font-size: 24px;
            font-weight: 600;
            line-height: 1.2;
            letter-spacing: -0.01em;
        }

        .stat small {
            display: block;
            margin-top: 8px;
            color: var(--muted);
            font-size: 11px;
            font-weight: 400;
        }

        .grid {
            display: grid;
            grid-template-columns: minmax(0, 1.2fr) minmax(360px, 0.8fr);
            gap: var(--spacing-lg);
            align-items: start;
        }

        .panel-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            padding: 16px 20px;
            border-bottom: 1px solid var(--line-light);
        }

        .panel-head h2 {
            color: var(--charcoal);
            font-size: 15px;
            font-weight: 600;
        }

        .panel-head span {
            display: block;
            margin-top: 2px;
            color: var(--muted);
            font-size: 11px;
        }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 14px;
            padding: 20px;
        }

        label {
            display: grid;
            gap: 6px;
            color: var(--muted);
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        input,
        select,
        textarea {
            width: 100%;
            min-height: 38px;
            border: 1px solid var(--line-light);
            border-radius: var(--radius);
            padding: 0 12px;
            background: var(--surface);
            color: var(--text);
            outline: none;
            font-size: 13px;
            transition: all 0.2s ease;
        }

        input:focus,
        select:focus,
        textarea:focus {
            border-color: var(--slate);
        }

        textarea {
            min-height: 80px;
            padding-top: 8px;
            resize: vertical;
        }

        .full { grid-column: 1 / -1; }

        .table-wrap { overflow-x: auto; }
        
        table {
            width: 100%;
            border-collapse: collapse;
        }
        
        th, td {
            padding: 14px 20px;
            border-bottom: 1px solid var(--line-light);
            text-align: left;
            vertical-align: middle;
            font-size: 13px;
        }

        th {
            color: var(--muted);
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 0.05em;
            text-transform: uppercase;
        }

        td strong {
            color: var(--charcoal);
            font-weight: 500;
        }

        td span {
            color: var(--muted);
            font-size: 12px;
        }

        tr:hover td {
            background: var(--surface-soft);
        }

        .thumb {
            width: 56px;
            height: 42px;
            border: 1px solid var(--line-light);
            border-radius: var(--radius);
            object-fit: cover;
            background: var(--surface-soft);
        }

        /* Badge Pills from DESIGN.md */
        .badge {
            display: inline-flex;
            min-height: 22px;
            align-items: center;
            justify-content: center;
            border-radius: 9999px;
            padding: 0 10px;
            background: var(--surface-soft);
            color: var(--muted);
            font-size: 11px;
            font-weight: 500;
            text-transform: uppercase;
            white-space: nowrap;
        }

        .badge.paid,
        .badge.success,
        .badge.emerald {
            background: var(--emerald-soft);
            color: var(--emerald);
        }

        .badge.warn,
        .badge.pending,
        .badge.amber {
            background: var(--amber-soft);
            color: var(--amber);
        }

        .badge.danger,
        .badge.rose {
            background: var(--rose-soft);
            color: var(--rose);
        }

        .list {
            display: grid;
            gap: 12px;
            padding: 20px;
        }

        .notice {
            display: grid;
            gap: 4px;
            border: 1px solid var(--line-light);
            border-radius: var(--radius);
            padding: 12px 14px;
            background: var(--surface-soft);
            transition: all 0.2s ease;
        }

        .notice:hover {
            border-color: var(--line);
            background: var(--surface);
        }

        .notice strong {
            color: var(--charcoal);
            font-size: 13px;
            font-weight: 500;
        }
        
        .notice p {
            margin: 0;
            color: var(--muted);
            font-size: 12px;
            line-height: 1.5;
        }

        .inline-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            align-items: center;
        }

        .icon-action {
            display: inline-grid;
            width: 34px;
            height: 34px;
            place-items: center;
            border: 1px solid var(--line-light);
            border-radius: var(--radius);
            background: var(--surface);
            color: var(--charcoal);
            font-size: 12px;
            transition: all 0.2s ease;
        }

        .icon-action:hover {
            border-color: var(--line);
            background: var(--surface-soft);
        }

        /* Monthly Sales Chart */
        .chart {
            display: flex;
            min-height: 220px;
            align-items: end;
            gap: 12px;
            padding: 24px 20px 20px;
        }

        .chart-bar {
            display: grid;
            flex: 1;
            min-width: 32px;
            gap: 8px;
            align-items: end;
        }

        .chart-bar i {
            display: block;
            min-height: 8px;
            border-radius: var(--radius-sm);
            background: var(--primary-container);
            transition: all 0.3s ease;
        }

        .chart-bar:hover i {
            background: var(--charcoal);
        }

        .chart-bar span {
            color: var(--muted);
            font-size: 11px;
            font-weight: 500;
            text-align: center;
        }

        .matrix {
            display: grid;
            gap: 8px;
        }

        .matrix-row {
            display: grid;
            grid-template-columns: 90px minmax(0, 1fr) 38px;
            gap: 10px;
            align-items: center;
        }

        .matrix-size {
            display: grid;
            height: 38px;
            place-items: center;
            border: 1px solid var(--line-light);
            border-radius: var(--radius);
            background: var(--surface-soft);
            color: var(--charcoal);
            font-weight: 600;
            font-size: 12px;
        }

        /* Live Chat Styles */
        .chat-shell {
            display: grid;
            min-height: 600px;
            grid-template-columns: 300px minmax(0, 1fr);
            border: 1px solid var(--line-light);
            border-radius: var(--radius-lg);
            background: var(--surface);
            overflow: hidden;
        }

        .chat-list {
            border-right: 1px solid var(--line-light);
            background: var(--surface-soft);
        }

        .chat-thread {
            display: grid;
            gap: 4px;
            border-bottom: 1px solid var(--line-light);
            padding: 14px 16px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .chat-thread:hover {
            background: rgba(0, 0, 0, 0.02);
        }

        .chat-thread.active {
            background: var(--surface);
        }

        .chat-thread strong {
            color: var(--charcoal);
            font-size: 13px;
            font-weight: 500;
        }

        .chat-thread p {
            margin: 0;
            color: var(--muted);
            font-size: 12px;
            line-height: 1.4;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .unread-dot {
            display: inline-block;
            width: 6px;
            height: 6px;
            border-radius: 999px;
            background: var(--emerald);
        }

        .chat-window {
            display: grid;
            grid-template-rows: auto 1fr auto;
            min-width: 0;
            background: var(--surface);
        }

        .chat-window-head {
            padding: 16px 20px;
            border-bottom: 1px solid var(--line-light);
        }

        .messages {
            display: grid;
            align-content: end;
            gap: 12px;
            padding: 20px;
            overflow-y: auto;
        }

        .bubble {
            max-width: min(520px, 75%);
            border: 1px solid var(--line-light);
            border-radius: var(--radius-lg);
            padding: 10px 14px;
            background: var(--surface-soft);
        }

        .bubble.admin {
            justify-self: end;
            border-color: rgba(27, 138, 90, 0.2);
            background: var(--emerald-soft);
            color: var(--emerald);
        }

        .bubble strong {
            display: block;
            margin-bottom: 4px;
            color: var(--charcoal);
            font-size: 11px;
            font-weight: 600;
        }

        .bubble p {
            margin: 0;
            color: var(--text);
            font-size: 13px;
            line-height: 1.5;
        }

        .chat-input {
            display: grid;
            grid-template-columns: 140px minmax(0, 1fr) auto;
            gap: 10px;
            border-top: 1px solid var(--line-light);
            padding: 16px;
            align-items: center;
        }

        @media (max-width: 1100px) {
            .layout { padding-left: 0; }
            aside { position: relative; width: auto; height: auto; border-right: none; border-bottom: 1px solid var(--line-light); }
            .sidebar-foot { border-top: 1px solid var(--line-light); padding-top: 16px; margin-top: 16px; }
            .grid, .chat-shell { grid-template-columns: 1fr; }
            .stats { grid-template-columns: repeat(2, minmax(0, 1fr)); }
            .global-search { width: 220px; }
        }

        @media (max-width: 720px) {
            .topbar { align-items: flex-start; flex-direction: column; padding: 16px; }
            .top-tools, .global-search { width: 100%; }
            .content { padding: 16px; }
            .stats, .form-grid, .chat-input { grid-template-columns: 1fr; }
            .button, .secondary-button, .danger-button { width: 100%; }
        }
    </style>
</head>
